# Copy to .env and fill in your values.

# Contact form → email. Get form ID from https://formspree.io (create form, set notification email to your email).
VITE_FORMSPREE_FORM_ID=

# Firebase (for real-time reviews). Get these from Firebase Console: Project settings > General > Your apps (Web app).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
