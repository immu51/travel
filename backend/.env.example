PORT=5000

# MongoDB: use EITHER MONGODB_URI (encode @ and other special chars in password as %40, %23, etc.) OR the 4 vars below (password is encoded automatically).
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/travel?retryWrites=true&w=majority
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_CLUSTER=cluster0.xxxxx.mongodb.net
MONGODB_DB=travel

# Required for admin login. Use the same SHA-256 hash as VITE_ADMIN_PASSWORD_HASH (frontend) so the same password works.
# Generate (from backend folder): node scripts/generate-admin-hash.js "yourPassword"
ADMIN_PASSWORD_HASH=

JWT_SECRET=your_random_secret_for_jwt
FRONTEND_ORIGIN=http://localhost:5173
