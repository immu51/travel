# Copy to .env and fill in your values.

# Backend API (MongoDB). When set, forms, content overrides and reviews use the API instead of Formspree/localStorage.
# Example: http://localhost:5000 or https://your-backend.railway.app
VITE_API_URL=

# Contact form → email. Used only when VITE_API_URL is not set. Get form ID from https://formspree.io
VITE_FORMSPREE_FORM_ID=

# Firebase (for real-time reviews when VITE_API_URL is not set). From Firebase Console > Project settings > Your apps.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional: for local-only admin login when VITE_API_URL is not set. SHA-256 hex of your admin password.
# VITE_ADMIN_PASSWORD_HASH=
